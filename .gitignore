# ==============================================================================
# simon-stack .gitignore
# ==============================================================================

# Claude Code local state (per-user permissions cache, not shared)
.claude/settings.local.json

# Backups created by setup-repo.sh when overwriting existing hooks
.claude/hooks/*.bak
.claude/hooks/*.bak-*
**/*.bak
**/*.bak-*

# simon-stack bootstrap cache (never committed — per-user VM local)
.simon-stack-src/
~/.simon-stack-src/

# Install-time backups of ~/.claude
.claude.bak-*/

# Environment files (never commit secrets)
.env
.env.local
.env.*.local

# Node / Bun
node_modules/
bun.lockb
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnp.*

# OS artifacts
.DS_Store
Thumbs.db
Desktop.ini
._*

# Editor / IDE
.vscode/
.idea/
*.swp
*.swo
*~
.project
.settings/

# Logs
*.log
/tmp/simon-stack-*.log

# Test / coverage
coverage/
.nyc_output/

# Temporary
*.tmp
*.temp
